	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\OpenTraceability\OpenTraceability.csproj">
			<GlobalPropertiesToRemove></GlobalPropertiesToRemove>
		</ProjectReference>
		<ProjectReference Include="..\OpenTraceability.GDST\OpenTraceability.GDST.csproj">
