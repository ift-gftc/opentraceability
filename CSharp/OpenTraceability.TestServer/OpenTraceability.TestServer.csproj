	</ItemGroup>

	<ItemGroup>
	  <Content Include="Data\beef-leather-example\events.jsonld" />
	</ItemGroup>
	<ItemGroup>
		<Folder Include="Services\" />
		<Folder Include="Services\Interfaces\" />
